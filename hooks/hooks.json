{
  "hooks": [
    {
      "type": "PostToolUse",
      "toolName": "Agent",
      "description": "Sub-agent completion: update state.json and log progress",
      "disabled": true,
      "command": "node hooks/on-agent-complete.js"
    },
    {
      "type": "PostToolUse",
      "toolName": "Bash",
      "pattern": "git commit",
      "description": "Commit event: log implementation progress",
      "disabled": true,
      "command": "node hooks/on-commit.js"
    }
  ]
}
