# Jira Gateway MCP — environment variables

# Required: Jira Cloud base URL (no trailing slash)
JIRA_BASE_URL=https://your-domain.atlassian.net

# Required: Jira API token (https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=

# Required: email associated with the API token
JIRA_USER_EMAIL=

# Optional (RI-22): path to shared/patterns.json. Auto-detected from project root if unset.
PATTERNS_PATH=

# Optional: path to custom patterns override
CUSTOM_PATTERNS_PATH=
