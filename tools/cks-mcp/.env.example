# cks-mcp — environment variables

# Optional: path to the SQLite index. Defaults to .coding-agent/index/ckv.db under cwd.
CKS_INDEX_PATH=

# Optional (RI-22): path to shared/patterns.json. Auto-detected from project root if unset.
CKS_PATTERNS_PATH=

# Optional override for the entropy/redactor pattern overlay.
CUSTOM_PATTERNS_PATH=

# Optional Ollama settings (Tier 1 embedder). RI-08: if Ollama is unreachable
# the server falls back to BM25 search automatically.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# Set to "1" to skip the Ollama probe and force BM25 mode.
CKS_DISABLE_OLLAMA=
