{
  "mcpServers": {
    "jira-gateway": {
      "command": "${CLAUDE_PLUGIN_ROOT}/../tools/jira-gateway-mcp/bin/jira-gateway-mcp",
      "args": [],
      "env": {
        "JIRA_BASE_URL": "${JIRA_BASE_URL}",
        "JIRA_API_TOKEN": "${JIRA_API_TOKEN}",
        "JIRA_USER_EMAIL": "${JIRA_USER_EMAIL}",
        "PATTERNS_PATH": "${CLAUDE_PLUGIN_ROOT}/../shared/patterns.json"
      }
    },
    "cks": {
      "command": "${CLAUDE_PLUGIN_ROOT}/../tools/cks-mcp/bin/cks-server",
      "args": [],
      "env": {
        "CKS_INDEX_PATH": "${CKS_INDEX_PATH}",
        "CKS_PATTERNS_PATH": "${CLAUDE_PLUGIN_ROOT}/../shared/patterns.json",
        "OLLAMA_BASE_URL": "${OLLAMA_BASE_URL}",
        "OLLAMA_EMBED_MODEL": "${OLLAMA_EMBED_MODEL}",
        "CKS_DISABLE_OLLAMA": "${CKS_DISABLE_OLLAMA}"
      }
    }
  }
}
